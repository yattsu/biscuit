# biscuit/.claudeignore

# SDK — huge, never changes
open-x4-sdk/

# Build output
.pio/
build/

# Fonts source (huge binary/generated)
lib/EpdFont/fontsrc/
lib/EpdFont/*.ttf
lib/EpdFont/*.otf

# Generated i18n (regenerated by build)
lib/I18n/I18nKeys.h
lib/I18n/I18nStrings.h
lib/I18n/I18nStrings.cpp

# Translations (only touch if adding new strings)
lib/I18n/translations/

# Python venv
.venv/

# Skills/tools not part of firmware
.skills/
bin/
tools/

# Docs images (binary)
docs/images/

# Scripts (build helpers, not firmware)
scripts/

# Test mocks (only for native preview)
test/

# Large generated files
*.generated.h
AUDIT_REPORT.md
